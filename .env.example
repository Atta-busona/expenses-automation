# Google Service Account credentials JSON file path
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account.json

# Google Drive folder ID for "SC Statements" folder
# (Get from the folder URL: https://drive.google.com/drive/folders/<THIS_ID>)
SC_STATEMENT_FOLDER_ID=

# Google Drive folder ID for "Payoneer Statements" folder (optional)
PAYONEER_STATEMENT_FOLDER_ID=

# Google Spreadsheet ID for the Expenses workbook (BUS-2026-Expenses)
# (Get from the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_ID>/edit)
EXPENSES_SPREADSHEET_ID=

# Google Spreadsheet ID for the Config workbook (Employee_Master_Template)
CONFIG_SPREADSHEET_ID=

# Template sheet name inside the Expenses spreadsheet
TEMPLATE_SHEET_NAME=Template

# Poll interval in seconds for watching the Drive folder (default: 60)
WATCH_POLL_INTERVAL_SECONDS=60

# Overwrite existing monthly sheet if it already exists
OVERWRITE_EXISTING=false
